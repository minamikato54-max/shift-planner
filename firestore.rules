rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.role == "staff";
      allow update: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }

    match /periods/{periodId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /availabilities/{docId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isSignedIn()
        && (request.resource.data.userId == request.auth.uid || isAdmin())
        && docId == request.resource.data.periodId + "_" + request.resource.data.userId;
      allow delete: if false;
    }

    match /assignments/{periodId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.confirmed == true);
      allow create, update: if isAdmin();
      allow delete: if false;
    }
  }
}
