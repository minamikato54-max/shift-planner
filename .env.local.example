NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server only, used only under app/api). Console > Project settings >
# Service accounts > Generate new private key, then transcribe the JSON contents here.
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the private key as a single line with literal \n escapes (converted to real
# newlines at runtime).
FIREBASE_ADMIN_PRIVATE_KEY=

# Gmail sending (developer's own Gmail account; enable 2-step verification, then issue
# an app password).
GMAIL_USER=
GMAIL_APP_PASSWORD=

# LINE Messaging API (a NEW channel dedicated to this app only; do not reuse another
# project's channel).
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
